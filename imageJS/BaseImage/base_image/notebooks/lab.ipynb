   "source": [
    "import oracledb\n",
    "import os\n",
    "\n",
    "conn = oracledb.connect(\n",
    "    user=os.getenv(\"DB_USER\"),\n",
    "    password=os.getenv(\"DB_PASSWORD\"),\n",
    "    dsn=os.getenv(\"DB_DSN\")\n",
    ")\n",
    "\n",
    "cursor = conn.cursor()\n",
    "cursor.execute(\"select * from customers\")\n",
    "\n",
    "print(cursor.fetchall())"
   ]
  }
